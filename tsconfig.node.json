@tailwind base;
@tailwind components;
@tailwind utilities;

/* LIGHT MODE — Construction-themed: earthy tones, teal primary, warm orange accents */
:root {
  --button-outline: rgba(0, 0, 0, 0.1);
  --badge-outline: rgba(0, 0, 0, 0.05);
  --opaque-button-border-intensity: -8;
  --elevate-1: rgba(0, 0, 0, 0.03);
  --elevate-2: rgba(0, 0, 0, 0.08);
  --background: 40 20% 97%;
  --foreground: 30 20% 10%;
  --border: 36 10% 88%;
  --card: 40 18% 98%;
  --card-foreground: 30 20% 10%;
  --card-border: 36 10% 92%;
  --sidebar: 200 20% 15%;
  --sidebar-foreground: 40 10% 92%;
  --sidebar-border: 200 18% 20%;
  --sidebar-primary: 174 80% 30%;
  --sidebar-primary-foreground: 0 0% 100%;
  --sidebar-accent: 200 15% 22%;
  --sidebar-accent-foreground: 40 10% 92%;
  --sidebar-ring: 174 80% 30%;
  --popover: 40 15% 96%;
  --popover-foreground: 30 20% 10%;
  --popover-border: 36 10% 88%;
  --primary: 174 80% 30%;
  --primary-foreground: 0 0% 100%;
  --secondary: 36 10% 90%;
  --secondary-foreground: 30 20% 10%;
  --muted: 36 8% 92%;
  --muted-foreground: 30 6% 45%;
  --accent: 36 12% 90%;
  --accent-foreground: 30 20% 10%;
  --destructive: 0 72% 45%;
  --destructive-foreground: 0 0% 98%;
  --input: 36 8% 78%;
  --ring: 174 80% 30%;
  --chart-1: 174 80% 30%;
  --chart-2: 25 85% 55%;
  --chart-3: 45 75% 50%;
  --chart-4: 260 55% 50%;
  --chart-5: 103 56% 38%;
  --font-sans: "Inter", "Helvetica Neue", sans-serif;
  --font-serif: Georgia, serif;
  --font-mono: "JetBrains Mono", Menlo, monospace;
  --radius: 0.5rem;
  --shadow-2xs: 0px 1px 0px 0px rgba(0,0,0,0.02);
  --shadow-xs: 0px 1px 2px 0px rgba(0,0,0,0.04);
  --shadow-sm: 0px 1px 3px 0px rgba(0,0,0,0.06), 0px 1px 2px -1px rgba(0,0,0,0.04);
  --shadow: 0px 2px 4px 0px rgba(0,0,0,0.06), 0px 1px 2px -1px rgba(0,0,0,0.04);
  --shadow-md: 0px 4px 8px -1px rgba(0,0,0,0.08), 0px 2px 4px -2px rgba(0,0,0,0.04);
  --shadow-lg: 0px 10px 20px -3px rgba(0,0,0,0.1), 0px 4px 6px -4px rgba(0,0,0,0.06);
  --shadow-xl: 0px 20px 30px -5px rgba(0,0,0,0.12), 0px 8px 10px -6px rgba(0,0,0,0.06);
  --shadow-2xl: 0px 25px 50px -12px rgba(0,0,0,0.25);
  --tracking-normal: 0em;
  --spacing: 0.25rem;

  --sidebar-primary-border: hsl(var(--sidebar-primary));
  --sidebar-accent-border: hsl(var(--sidebar-accent));
  --primary-border: hsl(var(--primary));
  --secondary-border: hsl(var(--secondary));
  --muted-border: hsl(var(--muted));
  --accent-border: hsl(var(--accent));
  --destructive-border: hsl(var(--destructive));
}

/* DARK MODE — Deep slate-charcoal with teal/orange accents */
.dark {
  --button-outline: rgba(255, 255, 255, 0.1);
  --badge-outline: rgba(255, 255, 255, 0.05);
  --opaque-button-border-intensity: 9;
  --elevate-1: rgba(255, 255, 255, 0.04);
  --elevate-2: rgba(255, 255, 255, 0.09);
  --background: 220 15% 8%;
  --foreground: 40 5% 90%;
  --border: 220 10% 18%;
  --card: 220 14% 10%;
  --card-foreground: 40 5% 90%;
  --card-border: 220 10% 15%;
  --sidebar: 220 18% 10%;
  --sidebar-foreground: 40 5% 90%;
  --sidebar-border: 220 12% 16%;
  --sidebar-primary: 174 55% 42%;
  --sidebar-primary-foreground: 0 0% 100%;
  --sidebar-accent: 220 12% 18%;
  --sidebar-accent-foreground: 40 5% 90%;
  --sidebar-ring: 174 55% 42%;
  --popover: 220 14% 12%;
  --popover-foreground: 40 5% 90%;
  --popover-border: 220 10% 18%;
  --primary: 174 55% 42%;
  --primary-foreground: 0 0% 100%;
  --secondary: 220 10% 18%;
  --secondary-foreground: 40 5% 90%;
  --muted: 220 8% 20%;
  --muted-foreground: 220 5% 55%;
  --accent: 220 10% 18%;
  --accent-foreground: 40 5% 90%;
  --destructive: 0 72% 45%;
  --destructive-foreground: 0 0% 98%;
  --input: 220 8% 28%;
  --ring: 174 55% 42%;
  --chart-1: 174 55% 50%;
  --chart-2: 25 80% 60%;
  --chart-3: 45 70% 55%;
  --chart-4: 260 50% 60%;
  --chart-5: 103 43% 50%;
  --shadow-2xs: 0px 1px 0px 0px rgba(0,0,0,0);
  --shadow-xs: 0px 1px 2px 0px rgba(0,0,0,0);
  --shadow-sm: 0px 1px 3px 0px rgba(0,0,0,0), 0px 1px 2px -1px rgba(0,0,0,0);
  --shadow: 0px 2px 4px 0px rgba(0,0,0,0), 0px 1px 2px -1px rgba(0,0,0,0);
  --shadow-md: 0px 4px 8px -1px rgba(0,0,0,0), 0px 2px 4px -2px rgba(0,0,0,0);
  --shadow-lg: 0px 10px 20px -3px rgba(0,0,0,0), 0px 4px 6px -4px rgba(0,0,0,0);
  --shadow-xl: 0px 20px 30px -5px rgba(0,0,0,0), 0px 8px 10px -6px rgba(0,0,0,0);
  --shadow-2xl: 0px 25px 50px -12px rgba(0,0,0,0);

  --sidebar-primary-border: hsl(var(--sidebar-primary));
  --sidebar-accent-border: hsl(var(--sidebar-accent));
  --primary-border: hsl(var(--primary));
  --secondary-border: hsl(var(--secondary));
  --muted-border: hsl(var(--muted));
  --accent-border: hsl(var(--accent));
  --destructive-border: hsl(var(--destructive));
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply font-sans antialiased bg-background text-foreground;
  }
}

/* Gantt chart custom scrollbar */
.gantt-scroll::-webkit-scrollbar {
  height: 8px;
}
.gantt-scroll::-webkit-scrollbar-track {
  @apply bg-muted rounded-full;
}
.gantt-scroll::-webkit-scrollbar-thumb {
  @apply bg-muted-foreground/30 rounded-full;
}
.gantt-scroll::-webkit-scrollbar-thumb:hover {
  @apply bg-muted-foreground/50;
}

@layer utilities {
  input[type='search']::-webkit-search-cancel-button {
    @apply hidden;
  }

  [contenteditable][data-placeholder]:empty::before {
    content: attr(data-placeholder);
    color: hsl(var(--muted-foreground));
    pointer-events: none;
  }

  .no-default-hover-elevate {
  }

  .no-default-active-elevate {
  }

  .toggle-elevate::before,
  .toggle-elevate-2::before {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0px;
    border-radius: inherit;
    z-index: -1;
  }

  .toggle-elevate.toggle-elevated::before {
    background-color: var(--elevate-2);
  }

  .border.toggle-elevate::before {
    inset: -1px;
  }

  .hover-elevate:not(.no-default-hover-elevate),
  .active-elevate:not(.no-default-active-elevate),
  .hover-elevate-2:not(.no-default-hover-elevate),
  .active-elevate-2:not(.no-default-active-elevate) {
    position: relative;
    z-index: 0;
  }

  .hover-elevate:not(.no-default-hover-elevate)::after,
  .active-elevate:not(.no-default-active-elevate)::after,
  .hover-elevate-2:not(.no-default-hover-elevate)::after,
  .active-elevate-2:not(.no-default-active-elevate)::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0px;
    border-radius: inherit;
    z-index: 999;
  }

  .hover-elevate:hover:not(.no-default-hover-elevate)::after,
  .active-elevate:active:not(.no-default-active-elevate)::after {
    background-color: var(--elevate-1);
  }

  .hover-elevate-2:hover:not(.no-default-hover-elevate)::after,
  .active-elevate-2:active:not(.no-default-active-elevate)::after {
    background-color: var(--elevate-2);
  }

  .border.hover-elevate:not(.no-hover-interaction-elevate)::after,
  .border.active-elevate:not(.no-active-interaction-elevate)::after,
  .border.hover-elevate-2:not(.no-hover-interaction-elevate)::after,
  .border.active-elevate-2:not(.no-active-interaction-elevate)::after {
    inset: -1px;
  }
}
